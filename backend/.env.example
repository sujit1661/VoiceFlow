# Flow — Environment Variables
# Built by Sujit Sadalage
# Copy this file to .env and fill in your values

# Required: Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Environment: "development" or "production"
ENVIRONMENT=development

# Allowed CORS origins (comma-separated). In production set this to your domain.
# Example: ALLOWED_ORIGINS=https://flow.yourdomain.com,https://www.yourdomain.com
# Leave empty in development — defaults to localhost
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000
